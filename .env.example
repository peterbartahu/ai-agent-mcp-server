# AI Study Helper Environment Variables
# Copy this to .env and fill in your actual values
# NEVER commit .env to git!

# LLM Configuration
USE_OPENAI=false
# OPENAI_API_KEY=sk-proj-YOUR-KEY-HERE     # Uncomment if using OpenAI
# OPENAI_MODEL=gpt-3.5-turbo               # Optional: specify model

# MongoDB Configuration (Local Development)
# MONGO_URL=mongodb://admin:password@localhost:27017/ai_agent_db

# MongoDB Configuration (Cloud - MongoDB Atlas)
# MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/ai_agent_db?retryWrites=true&w=majority

# AWS Deployment (set via 'eb setenv' command, not here)
# See AWS_DEPLOYMENT.md for instructions
